# Server Environment Variables
# Copy this file to .env and fill in the values

# Server
NODE_ENV=development
PORT=4000
HOST=localhost

# App
APP_NAME=RAANJAAI NATURALS
APP_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3000

# API
API_PREFIX=/api/v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/raanjaai_naturals

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-32chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-32ch
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies (optional — set in production)
# COOKIE_DOMAIN=

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# SMTP (optional — for password reset emails)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Cashfree Payments (Phase 10 — sandbox test mode)
# Get test credentials from https://merchant.cashfree.com/merchants/login
# CASHFREE_APP_ID=
# CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox

# OTP / SMS (configure in later phases)
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
